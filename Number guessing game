import random

print("===== Number Guessing Game =====")

while True:
    player_name = input("Enter your name: ")

    print("\nSelect Difficulty Level:")
    print("1. Easy (15 chances)")
    print("2. Medium (10 chances)")
    print("3. Hard (5 chances)")

    choice = input("Enter your choice (1/2/3): ")

    if choice == "1":
        chances = 15
    elif choice == "2":
        chances = 10
    else:
        chances = 5

    secret_number = random.randint(1, 100)

    print(f"\nWelcome {player_name}!")
    print("Guess the number between 1 and 100.")

    for attempt in range(1, chances + 1):
        guess = int(input(f"Attempt {attempt}/{chances}: Enter your guess: "))

        if guess < secret_number:
            print("Too Low!")
        elif guess > secret_number:
            print("Too High!")
        else:
            print(f"\nCongratulations {player_name}!")
            print(f"You guessed the number in {attempt} attempts.")
            break
    else:
        print("\nGame Over!")
        print("The correct number was:", secret_number)

    play_again = input("\nDo you want to play again? (yes/no): ").lower()

    if play_again != "yes":
        print("Thank you for playing!")
        break
